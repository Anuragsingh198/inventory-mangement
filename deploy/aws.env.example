# Copy to deploy/aws.env.local and fill in (this file is gitignored).
# Used ONLY by this project's deploy scripts — no global aws configure.

AWS_ACCESS_KEY_ID=AKIAxxxxxxxx
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Optional
# BACKEND_REPO=inventory-backend
# FRONTEND_REPO=inventory-frontend
# TAG=latest
